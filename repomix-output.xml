import * as THREE from 'three'
import { gsap } from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'

export class ScrollScene {
  constructor(scene, camera) {
    this.scene = scene
    this.camera = camera
    this.curve = null
    this.cameraProgress = 0
    this.targetProgress = 0
    this._tmpPos = new THREE.Vector3()
    this.init()
  }

  init() {
    this.buildCurve()
    this.bindScrollTrigger()
  }

  buildCurve() {
    // Camera path — sweeps through 3D space as user scrolls hero
    // Designed to feel cinematic: starts far back, sweeps left, ends close
    this.curve = new THREE.CatmullRomCurve3([
      new THREE.Vector3(0, 0, 8),      // t=0: camera far back, center
      new THREE.Vector3(-3, 1, 4),     // t=0.25: sweeps left and up
      new THREE.Vector3(0, 0, 1),      // t=0.5: passes through scene center
      new THREE.Vector3(3, -1, -2),    // t=0.75: sweeps right and down
      new THREE.Vector3(0, 0, -5),     // t=1: camera pushed through, scene behind
    ])
    this.curve.curveType = 'catmullrom'
    this.curve.tension = 0.5

    // Optional: visualize curve in dev (remove for production)
    if (import.meta.env.DEV) {
      const points = this.curve.getPoints(50)
      const geo = new THREE.BufferGeometry().setFromPoints(points)
      const line = new THREE.Line(geo, new THREE.LineBasicMaterial({
        color: 0xE8A87C, opacity: 0.2, transparent: true
      }))
      this.scene.add(line)
      this._debugLine = line
    }
  }

  bindScrollTrigger() {
    // Map 300vh hero scroll to camera path progress
    ScrollTrigger.create({
      trigger: '.hero-section',
      start: 'top top',
      end: 'bottom bottom',
      scrub: 1.5,
      onUpdate: (self) => {
        // Store target — actual camera update happens in render() for smoothness
        this.targetProgress = self.progress
      }
    })
  }

  // Called every frame from main.js — smooth camera lerp
  update(delta) {
    // Lerp camera progress for smooth follow (not instant snap)
    this.cameraProgress +=
      (this.targetProgress - this.cameraProgress) * (1 - Math.pow(0.04, delta))

    // Move camera along curve — reuse vector to avoid allocation
    this.curve.getPoint(this.cameraProgress, this._tmpPos)
    this.camera.position.copy(this._tmpPos)

    // Camera always looks toward scene center
    this.camera.lookAt(0, 0, 0)
  }

  dispose() {
    if (this._debugLine) {
      this._debugLine.geometry.dispose()
      this.scene.remove(this._debugLine)
    }
  }
}
