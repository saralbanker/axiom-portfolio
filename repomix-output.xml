/* 
  AXIOM Void Chrome Design System
  Primary Accent: Amber (#E8A87C)
  Secondary Accent: Cyan (#00D4FF) — Restricted to tech tags only
*/

:root {
  /* Colors */
  --void: #0A0A0F;
  --deep: #111118;
  --amber: #E8A87C;
  --cyan: #00D4FF;
  --steel: #8899AA;
  --white: #F0F4FF;
  
  /* Utilities */
  --glass: rgba(255, 255, 255, 0.05);
  --gb: rgba(255, 255, 255, 0.08);
  --rule: rgba(255, 255, 255, 0.07);
  
  /* Typography */
  --f1: 'Cormorant Garamond', serif;
  --f2: 'DM Mono', monospace;
  
  /* Layout */
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
  --g: clamp(24px, 8vw, 120px);
  --sv: clamp(80px, 10vw, 140px);
}

/* 1. Reset & Global */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

html {
  font-size: 16px;
  background: var(--void);
  color: var(--white);
  overflow-x: hidden;
}

body {
  font-family: var(--f2);
  line-height: 1.85;
  overflow-x: hidden;
}

a {
  color: inherit;
  text-decoration: none;
  transition: color 0.3s var(--ease);
}

button, input, select, textarea {
  font-family: inherit;
  background: none;
  border: none;
  color: inherit;
  outline: none;
}

.mono-xs {
  font-family: var(--f2);
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.22em;
}

.Cormorant { font-family: var(--f1); }

/* 2. WebGL Canvas */
#cv {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  pointer-events: none;
}

/* 3. Preloader */
.preloader {
  position: fixed;
  inset: 0;
  background: var(--void);
  z-index: 9000;
  display: flex;
  align-items: center;
  justify-content: center;
  clip-path: inset(0 0 0 0);
}

.pre-content-wrap {
  text-align: center;
  width: 100%;
}

.pre-label {
  color: var(--steel);
  margin-bottom: 24px;
}

.pre-count {
  font-family: var(--f1);
  font-size: 20vw;
  line-height: 0.8;
  color: var(--amber);
  font-weight: 500;
}

.pre-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 4px;
  background: rgba(255, 255, 255, 0.05);
}

.pre-bar-fill {
  height: 100%;
  width: 0%;
  background: var(--amber);
}

/* 4. Custom Cursor */
.cd, .cr {
  position: fixed;
  top: 0;
  left: 0;
  pointer-events: none;
  border-radius: 50%;
  z-index: 8999;
  transform: translate(-50%, -50%);
}

.cd {
  width: 8px;
  height: 8px;
  background: var(--amber);
  transition: width 0.3s var(--ease), height 0.3s var(--ease);
}

.cr {
  width: 40px;
  height: 40px;
  border: 1px solid rgba(232, 168, 124, 0.35);
  z-index: 8998;
}

.cd.on-link { width: 40px; height: 40px; background: rgba(232, 168, 124, 0.15); border: 1px solid var(--amber); }
.cr.on-link { opacity: 0; }

/* 5. Navigation */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--g);
  z-index: 1000;
  transition: all 0.4s var(--ease);
}

.nav.stuck {
  height: 64px;
  background: rgba(10, 10, 15, 0.85);
  backdrop-filter: blur(15px);
  border-bottom: 1px solid var(--rule);
}

.nav-logo {
  font-family: var(--f1);
  font-size: 1.5rem;
  font-weight: 500;
  letter-spacing: 0.1em;
}

.nav-logo span { color: var(--amber); }

.nav-links {
  display: flex;
  gap: 40px;
}

.nav-links a {
  font-size: 0.7rem;
  color: var(--steel);
}

.nav-links a:hover { color: var(--amber); }

.nav-actions {
  display: flex;
  align-items: center;
  gap: 24px;
}

.nav-cta {
  padding: 10px 20px;
  border: 1px solid var(--rule);
  font-size: 0.72rem;
}

.nav-cta:hover { border-color: var(--amber); color: var(--amber); }

.nav-hamburger {
  display: none;
  flex-direction: column;
  gap: 6px;
  cursor: pointer;
}

.nav-hamburger span {
  width: 24px;
  height: 1px;
  background: var(--white);
}

/* 6. Mobile Menu */
.mm {
  position: fixed;
  inset: 0;
  background: var(--void);
  z-index: 2000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: translateX(100%);
  transition: transform 0.6s cubic-bezier(0.85, 0, 0.15, 1);
}

.mm.open { transform: translateX(0); }

.mm-close {
  position: absolute;
  top: 32px;
  right: var(--g);
  color: var(--amber);
}

.mm-links {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32px;
}

.mm-links a {
  font-family: var(--f1);
  font-size: 3rem;
  font-weight: 500;
}

/* 7. Utilities */
.container {
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 var(--g);
}

.glass {
  background: var(--glass);
  backdrop-filter: blur(20px);
  border: 1px solid var(--gb);
}

.mono-xs { font-size: 0.65rem; color: var(--steel); letter-spacing: 0.3em; margin-bottom: 12px; display: block; }

/* 8. Scroll Container */
.scroll-container {
  position: relative;
  width: 100%;
}

/* 9. Sections */
.sec {
  position: relative;
  padding: var(--sv) 0;
  border-top: 1px solid var(--rule);
}

.no-pb { padding-bottom: 0; }

.sec-label {
  color: var(--amber);
  margin-bottom: 40px;
}

.sec-h2 {
  font-family: var(--f1);
  font-size: clamp(2.8rem, 5vw, 5.5rem);
  font-weight: 500;
  line-height: 0.95;
  margin-bottom: 60px;
}

.sec-h2 em {
  font-style: italic;
  color: var(--amber);
}

/* 10. Hero Section */
.hero-section {
  position: relative;
  height: 300vh;
}

.hero-sticky {
  position: sticky;
  top: 0;
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 var(--g);
  overflow: hidden;
}

.hero-content {
  max-width: 1200px;
}

.hero-h1 {
  font-family: var(--f1);
  font-size: clamp(5rem, 12vw, 14rem);
  line-height: 0.88;
  font-weight: 500;
  margin-bottom: 40px;
}

.hero-accent { color: var(--amber); }

.hero-services {
  margin-bottom: 48px;
}

.hero-dot {
  display: inline-block;
  width: 4px;
  height: 4px;
  background: var(--amber);
  border-radius: 50%;
  margin: 0 12px;
  vertical-align: middle;
}

.hero-ctas {
  display: flex;
  gap: 20px;
}

.scroll-hint {
  position: absolute;
  bottom: 40px;
  left: var(--g);
  display: flex;
  align-items: center;
  gap: 16px;
}

.scroll-line {
  width: 1px;
  height: 60px;
  background: var(--rule);
  position: relative;
  overflow: hidden;
}

.scroll-line::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 40%;
  background: var(--amber);
  animation: scroll-hint 2s infinite ease-in-out;
}

@keyframes scroll-hint {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(250%); }
}

/* 11. Buttons */
.btn-primary, .btn-secondary {
  display: inline-block;
  padding: 18px 36px;
  font-size: 0.72rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  transition: all 0.4s var(--ease);
  cursor: pointer;
}

.btn-primary {
  background: var(--amber);
  color: var(--void);
}

.btn-primary:hover {
  background: var(--white);
}

.btn-secondary {
  border: 1px solid var(--rule);
  color: var(--white);
}

.btn-secondary:hover {
  border-color: var(--amber);
  color: var(--amber);
}

/* 12. Marquee */
.marq-wrap {
  width: 100%;
  height: 64px;
  background: rgba(232, 168, 124, 0.04);
  border-top: 1px solid rgba(232, 168, 124, 0.2);
  border-bottom: 1px solid rgba(232, 168, 124, 0.2);
  display: flex;
  align-items: center;
  overflow: hidden;
}

.marq-track {
  display: flex;
  white-space: nowrap;
  animation: marq 20s linear infinite;
}

.marq-item {
  font-size: 0.9rem;
  color: rgba(0, 212, 255, 0.6);
  padding: 0 30px;
}

.marq-sep {
  color: rgba(232, 168, 124, 0.3);
}

@keyframes marq {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* 13. About */
.about-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 80px;
}

.about-quote h2 {
  font-family: var(--f1);
  font-size: clamp(2.2rem, 4vw, 3.8rem);
  line-height: 1;
  margin-bottom: 24px;
}

.about-quote em { font-style: italic; color: var(--amber); }

.stat-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--rule);
  margin-bottom: 60px;
  border: 1px solid var(--rule);
}

.stat-card {
  padding: 30px 20px;
  text-align: center;
}

.stat-n {
  font-family: var(--f1);
  font-size: clamp(2.5rem, 4vw, 4rem);
  color: var(--amber);
  line-height: 1;
  margin-bottom: 8px;
}

.stat-div {
  width: 40px;
  height: 1px;
  background: var(--amber);
  margin: 32px 0;
}

.about-text p {
  color: var(--steel);
  margin-bottom: 24px;
}

/* 14. Services */
.svc-list {
  margin-top: 40px;
}

.svc-row {
  display: grid;
  grid-template-columns: 80px 1fr 1.5fr 40px;
  align-items: center;
  padding: 40px 0;
  border-top: 1px solid var(--rule);
  transition: all 0.4s var(--ease);
  cursor: pointer;
}

.svc-row:last-child { border-bottom: 1px solid var(--rule); }

.svc-row:hover {
  padding-left: 20px;
  padding-right: 20px;
  background: rgba(255, 255, 255, 0.02);
}

.svc-name {
  font-family: var(--f1);
  font-size: 2.2rem;
  transition: color 0.4s var(--ease);
}

.svc-row:hover .svc-name { color: var(--amber); }

.svc-tech {
  color: var(--steel);
}

.svc-arr {
  font-size: 1.5rem;
  transition: transform 0.4s var(--ease);
}

.svc-row:hover .svc-arr {
  transform: translateX(10px);
  color: var(--amber);
}

/* 15. Filter Tabs */
.filter-tabs {
  display: flex;
  gap: 12px;
  margin-bottom: 60px;
}

.ftab {
  padding: 10px 24px;
  border: 1px solid var(--rule);
  color: var(--steel);
  cursor: pointer;
  transition: all 0.3s var(--ease);
}

.ftab.active {
  background: var(--amber);
  color: var(--void);
  border-color: var(--amber);
}

.ftab:not(.active):hover {
  border-color: var(--white);
  color: var(--white);
}

/* 16. Project Grid */
.project-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32px;
}

/* Card styles for Phase 3 Injection */
.pc {
  position: relative;
  overflow: hidden;
  border: 1px solid var(--gb);
  background: var(--glass);
  backdrop-filter: blur(20px);
  transition: border-color 0.5s var(--ease);
}

.pc:hover { border-color: rgba(232, 168, 124, 0.3); }

.pc-img-wrap {
  position: relative;
  aspect-ratio: 16/10;
  overflow: hidden;
  border-bottom: 1px solid var(--rule);
}

.pc-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s var(--ease);
}

.pc:hover .pc-img { transform: scale(1.05); }

.pc-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 40%, rgba(10,10,15,0.8));
  pointer-events: none;
}

.pc-body { padding: 32px; }

.pc-badge {
  position: absolute;
  top: 20px;
  right: 20px;
  padding: 4px 10px;
  background: rgba(0, 212, 255, 0.1);
  border: 1px solid var(--cyan);
  color: var(--cyan);
  z-index: 10;
}

.pc-feat {
  position: absolute;
  top: 20px;
  left: 20px;
  padding: 4px 10px;
  background: rgba(232, 168, 124, 0.15);
  border: 1px solid var(--amber);
  color: var(--amber);
  z-index: 10;
}

.pc-title {
  font-family: var(--f1);
  font-size: 2rem;
  margin-bottom: 8px;
  line-height: 1.1;
}

.pc-desc {
  color: var(--steel);
  margin-bottom: 24px;
}

.tag {
  display: inline-block;
  font-size: 0.6rem;
  color: var(--cyan);
  border: 1px solid rgba(0, 212, 255, 0.3);
  padding: 4px 8px;
  margin-right: 8px;
}

/* 17. Contact */
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 100px;
  align-items: start;
}

.contact-info p {
  font-size: 1.1rem;
  color: var(--white);
  margin-bottom: 40px;
}

.contact-details {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.contact-details a { color: var(--amber); }

.contact-form-wrap {
  padding: 60px;
}

.fg { margin-bottom: 40px; }

.fi, .fse, .fta {
  width: 100%;
  padding: 12px 0;
  border-bottom: 1px solid var(--rule);
  font-size: 1.2rem;
  color: var(--white);
  transition: border-color 0.4s var(--ease);
}

.fi:focus, .fse:focus, .fta:focus {
  border-bottom-color: var(--amber);
}

.fse option { background: var(--void); color: var(--white); }

.success-title { font-size: 3rem; color: var(--amber); margin-bottom: 12px; }

/* 18. Footer */
.footer {
  background: var(--deep);
  padding: 100px 0 60px;
  border-top: 1px solid var(--rule);
}

.footer-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 80px;
}

.footer-logo { font-size: 2.2rem; margin-bottom: 8px; }
.footer-logo span { color: var(--amber); }

.footer-nav {
  display: flex;
  gap: 40px;
}

.footer-nav a:hover { color: var(--amber); }

.footer-bot {
  display: flex;
  justify-content: space-between;
  padding-top: 40px;
  border-top: 1px solid var(--rule);
  color: var(--steel);
}

/* 19. Responsive 768px */
@media (max-width: 768px) {
  :root { --g: 24px; }
  
  .nav-links, .nav-cta { display: none; }
  .nav-hamburger { display: flex; }
  
  .about-grid, .contact-grid { grid-template-columns: 1fr; gap: 60px; }
  .project-grid { grid-template-columns: 1fr; }
  
  .svc-row { grid-template-columns: 50px 1fr 40px; }
  .svc-tech { display: none; }
  
  .stat-row { grid-template-columns: 1fr; }
  
  .contact-form-wrap { padding: 40px 24px; }
}

/* 20. Responsive 480px */
@media (max-width: 480px) {
  .hero-h1 { font-size: 4rem; }
  .hero-services { font-size: 0.6rem; }
  .hero-dot { margin: 0 6px; }
  .hero-ctas { flex-direction: column; }
  
  .svc-name { font-size: 1.8rem; }
  
  .footer-top { flex-direction: column; gap: 40px; }
  .footer-nav { flex-direction: column; gap: 16px; }
}

/* 21. Touch Device Overrides */
@media (hover: none) and (pointer: coarse) {
  #cv, .cd, .cr { display: none !important; }
  
  .hero-sticky {
    position: relative;
    height: auto;
    min-height: 100vh;
    justify-content: center;
  }
  
  .hero-section { height: auto; }
}
